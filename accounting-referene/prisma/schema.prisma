generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business      Business?
  memberships   Membership[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  brandName   String?
  teamSize    String
  website     String?
  phone       String?
  country     String   @default("India")
  currency    String   @default("Indian Rupee(INR, ₹)")
  hasGst      Boolean  @default(false)
  gstNumber   String?
  usedFor     String[]
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       Role[]
  memberships Membership[]
  invitations Invitation[]
  contacts    Contact[]
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  DELETED
}

/// An individual person associated with a business. A contact can later be
/// linked to one or more clients/vendors (linking is not yet persisted).
model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Basic information
  prefix      String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  country     String
  contactCode String? // user-facing "Contact ID"

  // Secondary contact details
  secondaryEmail String?
  secondaryPhone String?

  // Display picture (S3 URL)
  image String?

  // Tax & identification
  panNumber      String?
  aadhaarNumber  String?
  passportNumber String?

  // Social profiles
  linkedinUrl  String?
  xUrl         String?
  facebookUrl  String?
  githubUrl    String?

  // Address
  addressCountry String?
  state          String?
  district       String?
  city           String?
  building       String?
  postalCode     String?
  zipCode        String?
  street         String?

  status    ContactStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([businessId, status])
}

/// A named set of module/action permissions within a business.
/// The business owner is bootstrapped with an `isSystem` "Super Admin" role
/// that always implies full access (enforced in code, see lib/rbac.ts).
model Role {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  /// { [moduleKey]: { view, create, edit, delete, approve: boolean } }
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]

  @@unique([businessId, name])
}

/// Links a User to a Business. Every user with access to a business (including
/// the owner) has exactly one Membership row for that business.
model Membership {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isOwner     Boolean  @default(false)
  /// Optional per-user override. When null, effective permissions come from the role.
  permissions Json?
  status      String   @default("active") // active | inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, userId])
}

/// A pending email invitation to join a business with a role / permission set.
model Invitation {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// Optional per-user override applied to the membership on acceptance.
  permissions Json?
  token       String   @unique
  status      String   @default("pending") // pending | accepted | revoked
  invitedById String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, email])
}
