generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business             Business?
  memberships          Membership[]
  approvedQuotations   Quotation[]          @relation("QuotationApprover")
  quotationActivities  QuotationActivity[]
  notifications        Notification[]
  documents            Document[]           @relation("DocumentCreator")
  documentConversions  DocumentConversion[] @relation("ConversionCreator")
}

model Business {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  brandName   String?
  teamSize    String
  website     String?
  phone       String?
  country     String   @default("India")
  currency    String   @default("Indian Rupee(INR, ₹)")
  hasGst      Boolean  @default(false)
  gstNumber   String?
  usedFor     String[]
  category    String?
  manageInventory          Boolean @default(false)
  enableMultipleWarehouses Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       Role[]
  memberships Membership[]
  invitations Invitation[]
  contacts    Contact[]
  clients     Client[]
  warehouses  Warehouse[]
  products    Product[]
  quotations  Quotation[]
  payments    Payment[]

  // Vendor & relationship back-relations
  vendors             Vendor[]               @relation("BusinessVendors")
  buyerRelationships  BusinessRelationship[] @relation("BuyerRelationships")
  sellerRelationships BusinessRelationship[] @relation("SellerRelationships")

  // Document & conversion back-relations
  documents           Document[]
  documentConversions DocumentConversion[]

  businessSettings BusinessSettings?
  paymentAccounts  PaymentAccount[]
}

// ─── Business Settings (branding + finance defaults) ──────────────────────────

model BusinessSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Bank details
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankBranch        String?
  bankSwift         String?

  // UPI
  upiId    String?
  upiQrUrl String?   // S3 URL of uploaded QR image

  // Branding
  letterheadUrl String?   // S3 URL of letterhead image
  footerText    String?
  watermarkText String?
  watermarkUrl  String?   // S3 URL of watermark image (optional, text fallback)

  // Default design preferences (applied to new quotations)
  defaultTemplate   String?   // e.g. "professional"
  defaultThemeColor String?   // hex e.g. "#7438dc"
  defaultFontFamily String?   // e.g. "inter"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  DELETED
}

/// An individual person associated with a business. A contact can later be
/// linked to one or more clients/vendors (linking is not yet persisted).
model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Basic information
  prefix      String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  country     String
  contactCode String? // user-facing "Contact ID"

  // Secondary contact details
  secondaryEmail String?
  secondaryPhone String?

  // Display picture (S3 URL)
  image String?

  // Tax & identification
  panNumber      String?
  aadhaarNumber  String?
  passportNumber String?

  // Social profiles
  linkedinUrl  String?
  xUrl         String?
  facebookUrl  String?
  githubUrl    String?

  // Address
  addressCountry String?
  state          String?
  district       String?
  city           String?
  building       String?
  postalCode     String?
  zipCode        String?
  street         String?

  status    ContactStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  linkedClients ClientContact[]
  linkedVendors VendorContact[]

  @@index([businessId, status])
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Basic info
  logo         String?
  businessName String
  industry     String?
  country      String?
  city         String?
  clientType   ClientType @default(COMPANY)

  // Tax
  trn          String?
  vatNumber    String?
  taxTreatment String?

  // Billing address
  addressCountry String?
  state          String?
  district       String?
  addressCity    String?
  buildingNumber String?
  postalCode     String?
  streetAddress  String?

  // Shipping
  shippingName       String?
  shippingCountry    String?
  shippingState      String?
  shippingCity       String?
  shippingPostalCode String?
  shippingStreet     String?

  // Additional details
  businessAlias      String?
  uniqueKey          String?  @unique @default(cuid())
  email              String?
  showEmailInInvoice Boolean  @default(false)
  phoneCode          String?  @default("+971")
  phone              String?
  showPhoneInInvoice Boolean  @default(false)
  defaultDueDays     Int?
  paymentAccount     String?

  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  linkedContacts ClientContact[]
  quotations     Quotation[]
  documents      Document[]

  @@index([businessId, status])
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([clientId, contactId])
}

/// A named set of module/action permissions within a business.
/// The business owner is bootstrapped with an `isSystem` "Super Admin" role
/// that always implies full access (enforced in code, see lib/rbac.ts).
model Role {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  /// { [moduleKey]: { view, create, edit, delete, approve: boolean } }
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]

  @@unique([businessId, name])
}

/// Links a User to a Business. Every user with access to a business (including
/// the owner) has exactly one Membership row for that business.
model Membership {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isOwner     Boolean  @default(false)
  /// Optional per-user override. When null, effective permissions come from the role.
  permissions Json?
  status      String   @default("active") // active | inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, userId])
}

/// A pending email invitation to join a business with a role / permission set.
model Invitation {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// Optional per-user override applied to the membership on acceptance.
  permissions Json?
  token       String   @unique
  status      String   @default("pending") // pending | accepted | revoked
  invitedById String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, email])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

enum ItemType {
  PRODUCT
  SERVICE
}

enum TrackingMethod {
  NONE
  BATCHWISE
  SERIAL
  BATCH_SERIAL
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum StockAdjustmentType {
  INCOMING
  OUTGOING
}

model Warehouse {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name            String
  warehouseCode   String?
  vatNumber       String?

  country         String?
  state           String?
  city            String?
  postalCode      String?
  streetAddress   String?
  email           String?
  phone           String?

  location        String?
  contactInfo     String?
  notes           String?
  isDefault       Boolean  @default(false)
  warehouseStatus String   @default("ACTIVE") // ACTIVE | INACTIVE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLevels  WarehouseStock[]
  adjustments  StockAdjustment[]

  @@index([businessId])
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  itemType         ItemType       @default(PRODUCT)
  name             String
  sku              String?
  category         String?
  unit             String?
  hsnSac           String?
  canBeSold        Boolean        @default(true)
  manageStock      Boolean        @default(true)
  image            String?
  originalImage    String?
  description      String?
  tags             String[]

  // Accounting
  purchaseLedger   String?
  salesLedger      String?
  inventoryLedger  String?

  // Pricing & Taxation
  currency             String?
  buyingPrice          Float?
  sellingPrice         Float?
  landedCost           Float?
  taxRate              Float?
  priceInclusiveTax    Boolean @default(false)

  // Dimensions
  length       Float?
  breadth      Float?
  height       Float?
  grossWeight  Float?
  netWeight    Float?

  // Stock management
  trackingMethod TrackingMethod @default(NONE)
  reorderPoint   Int?
  overstockPoint Int?

  status    ProductStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  stockLevels     WarehouseStock[]
  adjustments     StockAdjustment[]
  quotationItems  QuotationItem[]
  documentItems   DocumentItem[]

  @@index([businessId, status])
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  quantity  Float @default(0)
  committed Float @default(0)

  @@unique([productId, warehouseId])
}

model StockAdjustment {
  id          String              @id @default(cuid())
  businessId  String
  productId   String
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  type          StockAdjustmentType
  quantity      Float
  rate          Float?
  adjustedValue Float?
  vendor        String?
  reason        String
  notes         String?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([productId])
}

// ─── Quotations ───────────────────────────────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SAVED
  SENT
  VIEWED
  APPROVED
  REJECTED
  CANCELLED
  PURCHASE_ORDER_CREATED
}

enum QuotationActivityAction {
  QUOTATION_SENT
  QUOTATION_VIEWED
  QUOTATION_APPROVED
  QUOTATION_REJECTED
  QUOTATION_PO_CREATED
}

model Quotation {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Header 
  quotationTitle  String?
  quotationNumber String
  quotationDate   DateTime  @default(now())
  validTillDate   DateTime?
  subtitle        String?
  logo            String?
  currency        String    @default("AED")

  // Quotation From (business snapshot / overrides)
  fromName    String?
  fromAddress String?
  fromGstin   String?
  fromPan     String?

  // Quotation For (client)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName    String?
  clientAddress String?
  clientGstin   String?

  // Shipping & transport (optional block)
  shipFromWarehouseId String?
  shippingName        String?
  shippingAddress     String?
  shippingPostalCode  String?
  shippingState       String?
  transporterName     String?
  distance            String?
  vehicleType         String?
  vehicleNumber       String?
  transportDocNumber  String?
  transactionType     String?

  // Discount & additional charges (quotation-level)
  discountLabel     String?
  discountAmount    Float @default(0)
  additionalCharges Json  @default("[]")  // [{label, amount}]

  // Totals snapshot (computed from items)
  subTotal      Float @default(0)
  totalTax      Float @default(0)
  totalDiscount Float @default(0)
  totalQuantity Float @default(0)
  totalAmount   Float @default(0)
  amountInWords String?

  // Extras
  termsAndConditions String?
  notes              String?
  signature          String?
  additionalInfo     String?
  contactDetails     String?
  attachments        String[]
  customFields       Json     @default("[]")  // [{label, value}]

  // Advanced display settings (JSON blob of toggle states)
  settings Json @default("{}")

  status    QuotationStatus @default(DRAFT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Approval workflow
  approvalToken     String?   @unique
  sentAt            DateTime?
  viewedAt          DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  purchaseOrderCreatedAt  DateTime?
  rejectionReason         String?
  approvedByUserId  String?
  approvedByUser    User?     @relation("QuotationApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  // Business relationship (set when quotation is approved)
  businessRelationshipId String?
  businessRelationship   BusinessRelationship? @relation(fields: [businessRelationshipId], references: [id], onDelete: SetNull)

  items      QuotationItem[]
  activities QuotationActivity[]

  @@index([businessId, status])
}

model QuotationActivity {
  id          String                  @id @default(cuid())
  quotationId String
  quotation   Quotation               @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  action      QuotationActivityAction
  userId      String?                 // null for anonymous public views (e.g. VIEWED)
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadata    Json                    @default("{}")
  createdAt   DateTime                @default(now())

  @@index([quotationId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Snapshot fields
  name        String
  sku         String?
  hsnSac      String?
  unit        String?
  description String?
  image       String?
  groupName   String?

  quantity  Float @default(1)
  rate      Float @default(0)
  discount  Float @default(0)
  taxRate   Float @default(0)
  taxAmount Float @default(0)
  amount    Float @default(0)
  total     Float @default(0)
  sortOrder Int   @default(0)
}

// ─── Vendors & Business Relationships ────────────────────────────────────────

enum VendorStatus {
  ACTIVE
  ARCHIVED
}

enum VendorType {
  INDIVIDUAL
  COMPANY
}

enum BusinessRelationshipStatus {
  ACTIVE
  BLOCKED
}

/// A supplier/vendor stored in the buyer's business. Populated automatically when a
/// quotation from the seller is approved, or added manually.
model Vendor {
  id               String       @id @default(cuid())
  businessId       String                            // BUYER's business (tenant scope)
  business         Business     @relation("BusinessVendors", fields: [businessId], references: [id], onDelete: Cascade)
  linkedBusinessId String?                           // SELLER's business id; null for manually-added vendors

  name       String
  email      String?
  phone      String?
  website    String?
  address    String?   // legacy free-text; kept for backward compat
  gstNumber  String?

  // Extended fields (mirrors Client model)
  logo           String?
  industry       String?
  country        String?
  city           String?
  vendorType     VendorType @default(COMPANY)

  // Tax
  trn            String?
  vatNumber      String?
  taxTreatment   String?

  // Structured billing address
  addressCountry String?
  state          String?
  district       String?
  addressCity    String?
  buildingNumber String?
  postalCode     String?
  streetAddress  String?

  // Additional details
  businessAlias     String?
  phoneCode         String?  @default("+971")
  showEmailInDocs   Boolean  @default(false)
  showPhoneInDocs   Boolean  @default(false)
  defaultDueDays    Int?
  paymentAccount    String?

  status    VendorStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  linkedContacts VendorContact[]

  // NULL values are distinct in PG, so manual vendors (linkedBusinessId = NULL) don't collide with each other
  @@unique([businessId, linkedBusinessId])
  @@index([businessId, status])
}

model VendorContact {
  id        String  @id @default(cuid())
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([vendorId, contactId])
}

/// Persistent link between a buyer business and a seller business, created when the first
/// quotation from the seller is approved. Serves as the spine for future transaction history.
model BusinessRelationship {
  id               String                     @id @default(cuid())
  buyerBusinessId  String
  buyerBusiness    Business                   @relation("BuyerRelationships", fields: [buyerBusinessId], references: [id], onDelete: Cascade)
  sellerBusinessId String
  sellerBusiness   Business                   @relation("SellerRelationships", fields: [sellerBusinessId], references: [id], onDelete: Cascade)

  status BusinessRelationshipStatus @default(ACTIVE)

  // Transaction history — quotations already linked; POs / invoices / payments added in future phases
  quotations Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerBusinessId, sellerBusinessId])
  @@index([sellerBusinessId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  QUOTATION_SENT
  QUOTATION_VIEWED
  QUOTATION_APPROVED
  QUOTATION_REJECTED
  VENDOR_LINKED
  PURCHASE_ORDER_RECEIVED // reserved — Phase 4/5
  INVOICE_RECEIVED        // reserved — Phase 4/5
  PAYMENT_RECEIVED        // reserved — Phase 4/5
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       NotificationType
  isRead     Boolean          @default(false)
  entityType String?          // e.g. "QUOTATION", "VENDOR"
  entityId   String?          // the relevant document id for deep-linking
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Documents (unified conversion target) ────────────────────────────────────

enum DocumentType {
  INVOICE
  PURCHASE_ORDER
  SALES_ORDER
  PROFORMA_INVOICE
  DELIVERY_CHALLAN
}

enum DocumentStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model Document {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type           DocumentType
  documentNumber String
  documentDate   DateTime     @default(now())
  validTillDate  DateTime?
  title          String?
  subtitle       String?
  logo           String?
  currency       String       @default("AED")

  // From (business snapshot)
  fromName    String?
  fromAddress String?
  fromGstin   String?
  fromPan     String?

  // Client
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName    String?
  clientAddress String?
  clientGstin   String?

  // Shipping & transport
  shipFromWarehouseId String?
  shippingName        String?
  shippingAddress     String?
  shippingPostalCode  String?
  shippingState       String?
  transporterName     String?
  distance            String?
  vehicleType         String?
  vehicleNumber       String?
  transportDocNumber  String?
  transactionType     String?

  // Discount & additional charges
  discountLabel     String?
  discountAmount    Float @default(0)
  additionalCharges Json  @default("[]")

  // Totals snapshot
  subTotal      Float @default(0)
  totalTax      Float @default(0)
  totalDiscount Float @default(0)
  totalQuantity Float @default(0)
  totalAmount   Float @default(0)
  amountInWords String?

  // Extras
  termsAndConditions String?
  notes              String?
  signature          String?
  additionalInfo     String?
  contactDetails     String?
  attachments        String[]
  customFields       Json     @default("[]")
  settings           Json     @default("{}")

  status          DocumentStatus @default(ISSUED)
  sentAt          DateTime?
  purchasedAt     DateTime?
  approvalToken   String?        @unique
  createdByUserId String?
  createdByUser   User?          @relation("DocumentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items    DocumentItem[]
  payments Payment[]

  @@index([businessId, type, status])
  @@index([businessId, createdAt])
}

model DocumentItem {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Snapshot fields — identical to QuotationItem
  name        String
  sku         String?
  hsnSac      String?
  unit        String?
  description String?
  image       String?
  groupName   String?

  quantity  Float @default(1)
  rate      Float @default(0)
  discount  Float @default(0)
  taxRate   Float @default(0)
  taxAmount Float @default(0)
  amount    Float @default(0)
  total     Float @default(0)
  sortOrder Int   @default(0)
}

// ─── Document Conversion Audit ────────────────────────────────────────────────

model DocumentConversion {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  sourceType String // "QUOTATION" today; can hold DocumentType values in future phases
  sourceId   String
  targetType String // DocumentType value
  targetId   String

  createdByUserId String?
  createdBy       User?    @relation("ConversionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  // One conversion per (source, target type) — prevents duplicate invoices from the same quotation
  @@unique([sourceType, sourceId, targetType])
  @@index([businessId, sourceType, sourceId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  ACCOUNT_TRANSFER
  CASH
  CHEQUE
  UPI
  CARD
  OTHER
}

model Payment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  amountReceived    Float
  transactionCharge Float         @default(0)
  tdsWithheld       Float         @default(0)
  amountToSettle    Float

  paymentDate DateTime
  method      PaymentMethod @default(ACCOUNT_TRANSFER)
  refId       String?
  notes       String?
  attachments String[]

  status           PaymentStatus @default(PENDING)
  recordedByUserId String?
  recordedByName   String?
  approvedByUserId String?
  approvedAt       DateTime?

  paymentAccountId String?
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status])
  @@index([documentId])
}

// ─── Payment Accounts ─────────────────────────────────────────────────────────

enum PaymentAccountType {
  BANK
  EMPLOYEE
  OTHER
}

model PaymentAccount {
  id         String             @id @default(cuid())
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       PaymentAccountType @default(BANK)

  displayName String

  // Bank-specific fields
  accountHolderName String?
  bankName          String?
  accountNumber     String?
  ifsc              String?
  branch            String?
  accountType       String?   // "SAVINGS" | "CURRENT"
  upiId             String?

  // Extended fields
  country             String?
  currency            String?
  swift               String?
  customFields        Json?     // [{ label: string, value: string }]
  linkedBankAccountId String?

  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}
