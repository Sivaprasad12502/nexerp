generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business      Business?
  memberships   Membership[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  brandName   String?
  teamSize    String
  website     String?
  phone       String?
  country     String   @default("India")
  currency    String   @default("Indian Rupee(INR, ₹)")
  hasGst      Boolean  @default(false)
  gstNumber   String?
  usedFor     String[]
  category    String?
  manageInventory          Boolean @default(false)
  enableMultipleWarehouses Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       Role[]
  memberships Membership[]
  invitations Invitation[]
  contacts    Contact[]
  clients     Client[]
  warehouses  Warehouse[]
  products    Product[]
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  DELETED
}

/// An individual person associated with a business. A contact can later be
/// linked to one or more clients/vendors (linking is not yet persisted).
model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Basic information
  prefix      String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  country     String
  contactCode String? // user-facing "Contact ID"

  // Secondary contact details
  secondaryEmail String?
  secondaryPhone String?

  // Display picture (S3 URL)
  image String?

  // Tax & identification
  panNumber      String?
  aadhaarNumber  String?
  passportNumber String?

  // Social profiles
  linkedinUrl  String?
  xUrl         String?
  facebookUrl  String?
  githubUrl    String?

  // Address
  addressCountry String?
  state          String?
  district       String?
  city           String?
  building       String?
  postalCode     String?
  zipCode        String?
  street         String?

  status    ContactStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  linkedClients ClientContact[]

  @@index([businessId, status])
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Basic info
  logo         String?
  businessName String
  industry     String?
  country      String?
  city         String?
  clientType   ClientType @default(COMPANY)

  // Tax
  trn          String?
  vatNumber    String?
  taxTreatment String?

  // Billing address
  addressCountry String?
  state          String?
  district       String?
  addressCity    String?
  buildingNumber String?
  postalCode     String?
  streetAddress  String?

  // Shipping
  shippingName       String?
  shippingCountry    String?
  shippingState      String?
  shippingCity       String?
  shippingPostalCode String?
  shippingStreet     String?

  // Additional details
  businessAlias      String?
  uniqueKey          String?  @unique @default(cuid())
  email              String?
  showEmailInInvoice Boolean  @default(false)
  phoneCode          String?  @default("+971")
  phone              String?
  showPhoneInInvoice Boolean  @default(false)
  defaultDueDays     Int?
  paymentAccount     String?

  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  linkedContacts ClientContact[]

  @@index([businessId, status])
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([clientId, contactId])
}

/// A named set of module/action permissions within a business.
/// The business owner is bootstrapped with an `isSystem` "Super Admin" role
/// that always implies full access (enforced in code, see lib/rbac.ts).
model Role {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  /// { [moduleKey]: { view, create, edit, delete, approve: boolean } }
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]

  @@unique([businessId, name])
}

/// Links a User to a Business. Every user with access to a business (including
/// the owner) has exactly one Membership row for that business.
model Membership {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isOwner     Boolean  @default(false)
  /// Optional per-user override. When null, effective permissions come from the role.
  permissions Json?
  status      String   @default("active") // active | inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, userId])
}

/// A pending email invitation to join a business with a role / permission set.
model Invitation {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// Optional per-user override applied to the membership on acceptance.
  permissions Json?
  token       String   @unique
  status      String   @default("pending") // pending | accepted | revoked
  invitedById String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, email])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

enum ItemType {
  PRODUCT
  SERVICE
}

enum TrackingMethod {
  NONE
  BATCHWISE
  SERIAL
  BATCH_SERIAL
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum StockAdjustmentType {
  INCOMING
  OUTGOING
}

model Warehouse {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name            String
  warehouseCode   String?
  location        String?
  contactInfo     String?
  notes           String?
  isDefault       Boolean  @default(false)
  warehouseStatus String   @default("ACTIVE") // ACTIVE | INACTIVE
  vatNumber       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLevels  WarehouseStock[]
  adjustments  StockAdjustment[]

  @@index([businessId])
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  itemType         ItemType       @default(PRODUCT)
  name             String
  sku              String?
  category         String?
  unit             String?
  hsnSac           String?
  canBeSold        Boolean        @default(true)
  manageStock      Boolean        @default(true)
  image            String?
  originalImage    String?
  description      String?
  tags             String[]

  // Accounting
  purchaseLedger   String?
  salesLedger      String?
  inventoryLedger  String?

  // Pricing & Taxation
  currency             String?
  buyingPrice          Float?
  sellingPrice         Float?
  landedCost           Float?
  taxRate              Float?
  priceInclusiveTax    Boolean @default(false)

  // Dimensions
  length       Float?
  breadth      Float?
  height       Float?
  grossWeight  Float?
  netWeight    Float?

  // Stock management
  trackingMethod TrackingMethod @default(NONE)
  reorderPoint   Int?
  overstockPoint Int?

  status    ProductStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  stockLevels WarehouseStock[]
  adjustments StockAdjustment[]

  @@index([businessId, status])
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  quantity  Float @default(0)
  committed Float @default(0)

  @@unique([productId, warehouseId])
}

model StockAdjustment {
  id          String              @id @default(cuid())
  businessId  String
  productId   String
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  type          StockAdjustmentType
  quantity      Float
  rate          Float?
  adjustedValue Float?
  vendor        String?
  reason        String
  notes         String?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([productId])
}
